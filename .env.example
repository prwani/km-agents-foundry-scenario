# Copy to .env for local development only. Do not commit real values.
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini
KM_AGENTS_ENVIRONMENT=development

# Comma-separated public IPv4 addresses that may call the Foundry endpoint.
# Include the developer public IP and KM portal/container app egress IPs.
ALLOWED_PUBLIC_IPS=203.0.113.10,198.51.100.20

# Agent names/endpoints are populated after deployment.
PROMPT_ORCHESTRATOR_AGENT_NAME=km-prompt-orchestrator
HOSTED_CASE_STUDY_AGENT_NAME=km-hosted-case-study-agent
PROMPT_GENERATOR_A2A_CONNECTION_ID=
PROMPT_VALIDATOR_A2A_CONNECTION_ID=

# Bundled canonical template and policy used by both agent stacks.
CASE_STUDY_TEMPLATE_PATH=assets/templates/contoso-case-study-template.pptx
TEMPLATE_POLICY_PATH=assets/templates/contoso-template-policy.json
MAX_REPAIR_ATTEMPTS=2

# Required for Entra bearer validation and Foundry OBO invocation.
# For local development only, use a test app registration and an uncommitted secret.
ENTRA_TENANT_ID=
ENTRA_PORTAL_CLIENT_ID=
ENTRA_API_AUDIENCE=api://<portal-api-app-client-id>
ENTRA_CLIENT_SECRET=

# Development can use short-lived in-memory artifacts. Production requires Blob storage.
ARTIFACT_STORAGE_MODE=memory
ARTIFACT_OWNER_HASH_SALT=
AZURE_STORAGE_BLOB_ENDPOINT=
ARTIFACT_CONTAINER_NAME=
