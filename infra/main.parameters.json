{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "namePrefix": {
      "value": "kmagents"
    },
    "allowedPublicIps": {
      "value": [
        "${ALLOWED_PUBLIC_IP}"
      ]
    },
    "budgetContactEmails": {
      "value": []
    },
    "entraTenantId": {
      "value": "${ENTRA_TENANT_ID}"
    },
    "entraPortalClientId": {
      "value": "${ENTRA_PORTAL_CLIENT_ID}"
    },
    "entraApiAudience": {
      "value": "${ENTRA_API_AUDIENCE}"
    },
    "foundryUserGroupObjectId": {
      "value": "${FOUNDRY_USER_GROUP_OBJECT_ID}"
    },
    "portalEntraClientSecret": {
      "value": "${ENTRA_CLIENT_SECRET}"
    },
    "artifactOwnerHashSalt": {
      "value": "${ARTIFACT_OWNER_HASH_SALT}"
    }
  }
}
